library(FactoMineR)
library(factoextra)
library(dplyr)
data <- read.csv("freMTPL2freq.csv")
View(data)
data_quant <- data %>%
select(ClaimNb, Exposure, VehPower, VehAge, DrivAge, BonusMalus, Density)
data_quant_reduit <- data_quant[1:5000, ]
View(data_quant_reduit)
data_quali <- data %>%
select(VehBrand, VehGas, Area, Region)
data_quali_reduit <- data_quali[1:5000, ]
res.pca <- PCA(data_quant_reduit,
scale.unit = TRUE,   # standardisation
ncp = 5,             # nombre de dimensions
graph = FALSE)
eig.val <- res.pca$eig
print(eig.val)
fviz_eig(res.pca, addlabels = TRUE)
fviz_pca_var(res.pca,
col.var = "contrib",
gradient.cols = c("blue", "orange", "red"),
repel = TRUE)
fviz_pca_ind(res.pca,
alpha.ind = 0.2)
fviz_contrib(res.pca, choice = "var", axes = 1, top = 10)
fviz_contrib(res.pca, choice = "var", axes = 2, top = 10)
data_clean <- data %>%
select(ClaimNb, Exposure, VehPower, VehAge, DrivAge, BonusMalus, Density,
VehBrand, VehGas, Area, Region) %>%
na.omit()
res.pca.quali <- PCA(data_clean,
scale.unit = TRUE,
quali.sup = 8:11,   # colonnes qualitatives
graph = FALSE)
fviz_pca_biplot(res.pca.quali,
repel = TRUE)
data <- read.csv("freMTPL2freq.csv")
data_reduit <- data[1:5000, ]
View(data_reduit)
# Variables quantitatives (pour ACP)
data_quant <- data_reduit %>%
select(ClaimNb, Exposure, VehPower, VehAge, DrivAge, BonusMalus, Density)
View(data_quant)
data_quali <- data_reduit %>%
select(VehBrand, VehGas, Area, Region)
View(data_quali)
res.pca <- PCA(data_quant,
scale.unit = TRUE,   # standardisation
ncp = 5,             # nombre de dimensions
graph = FALSE)
eig.val <- res.pca$eig
print(eig.val)
fviz_eig(res.pca, addlabels = TRUE)
fviz_pca_var(res.pca,
col.var = "contrib",
gradient.cols = c("blue", "orange", "red"),
repel = TRUE)
fviz_pca_ind(res.pca,
alpha.ind = 0.2)
fviz_contrib(res.pca, choice = "var", axes = 1, top = 10)
fviz_contrib(res.pca, choice = "var", axes = 2, top = 10)
data_clean <- data_reduit %>%
select(ClaimNb, Exposure, VehPower, VehAge, DrivAge, BonusMalus, Density,
VehBrand, VehGas, Area, Region) %>%
na.omit()
# ACP avec variables qualitatives en supplémentaires
res.pca.quali <- PCA(data_clean,
scale.unit = TRUE,
quali.sup = 8:11,   # colonnes qualitatives
graph = FALSE)
fviz_pca_biplot(res.pca.quali,
repel = TRUE)
fviz_pca_var(res.pca.quali, repel = TRUE)
fviz_pca_ind(res.pca.quali,
habillage = "Area",   # exemple
addEllipses = TRUE)
?PCA
