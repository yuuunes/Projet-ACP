library(FactoMineR)
library(factoextra)
library(dplyr)
# =========================
# 2. Import des données
# =========================
data <- read.csv("freMTPL2freq.csv")
data_reduit <- data[1:100, ]
# Manipulation des données
rownames(data_reduit) <- data_reduit$IDpol
data_reduit$IDpol <- NULL
View(data_reduit)
# =========================
# 5. ACP (centrée-réduite)
# =========================
res.pca <- PCA(data_reduit,
scale.unit = TRUE,   # standardisation
ncp = 5,            # nombre de dimensions
quali.sup = c(7, 8, 9, 11), # variables qualitatives ou supplémaentaires
graph = TRUE)
summary(res.pca)
?dev.off
pdf("cercle_corr.pdf", width = 7, height = 7)
fviz_pca_var(res.pca)
dev.off()
fviz_eig(res.pca, addlabels = TRUE)
pdf("Variance expliquée", width = 10, height = 7)
fviz_eig(res.pca, addlabels = TRUE)
dev.off()
# Scree plot (variance expliquée)
pdf("Variance expliquée.pdf", width = 10, height = 7)
fviz_eig(res.pca, addlabels = TRUE)
dev.off()
pdf("Biplot", width = 10, height = 7)
fviz_pca_biplot(res.pca,
repel = TRUE)
def.off()
pdf("Biplot.pdf", width = 10, height = 7)
fviz_pca_biplot(res.pca,
repel = TRUE)
dev.off()
fviz_contrib(res.pca, choice = "var", axes = 1, top = 10)
pdf("Contribution des Variables au premier axe.pdf", width = 10, height = 7)
fviz_contrib(res.pca, choice = "var", axes = 1, top = 10)
dev.off()
pdf("Contribution des Variables au deuxième axe.pdf", width = 10, height = 7)
fviz_contrib(res.pca, choice = "var", axes = 2, top = 10)
dev.off()
fviz_pca_ind(res.pca,
habillage = "Area")
pdf("Visualisation des modalités qualitatives.pdf", width = 10, height = 7)
fviz_pca_ind(res.pca,
habillage = "Area")
dev.off()
fviz_pca_ind(res.pca,
habillage = "Region")
pdf("Visualisation des modalités qualitatives.pdf", width = 10, height = 7)
fviz_pca_ind(res.pca,
habillage = "Region")
dev.off()
summary(res.pca)
eig.val <- res.pca$eig
print(eig.val)
